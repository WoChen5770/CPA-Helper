## 数据库设计

### 1. model_checker_settings (配置表)
存储在 `app_settings` 表中新增字段：
```sql
ALTER TABLE app_settings ADD COLUMN model_checker_settings TEXT DEFAULT '{}';
```

配置 JSON 结构：
```json
{
  "schedule_cron": "0 */6 * * *",
  "timeout_seconds": 30,
  "max_retries": 2,
  "enabled": false,
  "auto_start_daemon": false
}
```

### 2. model_checker_tracked_models (被监控的模型及其配置)
```sql
CREATE TABLE model_checker_tracked_models (
  model_id TEXT PRIMARY KEY,           -- 模型 ID（如 "claude-3-5-sonnet-20241022"）
  provider TEXT,                        -- 提供商（如 "anthropic"）
  enabled INTEGER DEFAULT 1,            -- 是否启用监控（0/1）
  check_interval_minutes INTEGER DEFAULT 60,  -- 巡检间隔（分钟）
  timeout_seconds INTEGER DEFAULT 30,  -- 单次检查超时（秒）
  max_retries INTEGER DEFAULT 2,       -- 最大重试次数
  alert_on_unavailable INTEGER DEFAULT 1,     -- 不可用时是否告警（0/1）
  last_status TEXT,                     -- 最后状态（available/unavailable/error）
  last_available_keys TEXT,             -- 最后可用的 Key 列表（JSON 数组）
  last_checked_at TEXT,                 -- 最后检查时间
  last_available_at TEXT,               -- 最后可用时间
  first_seen_at TEXT,                   -- 首次发现时间
  created_at TEXT DEFAULT (datetime('now')),
  updated_at TEXT DEFAULT (datetime('now'))
);
```

### 3. model_checker_runs (巡检运行记录)
```sql
CREATE TABLE model_checker_runs (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  mode TEXT NOT NULL,                   -- 运行模式（once/daemon）
  state TEXT NOT NULL,                  -- 状态（running/completed/failed）
  detail TEXT,                          -- 详细信息
  started_at TEXT,                      -- 开始时间
  finished_at TEXT,                     -- 结束时间
  total_models INTEGER DEFAULT 0,       -- 检查的模型总数
  available_models INTEGER DEFAULT 0,   -- 可用的模型数
  unavailable_models INTEGER DEFAULT 0, -- 不可用的模型数
  newly_available INTEGER DEFAULT 0,    -- 新增可用
  newly_unavailable INTEGER DEFAULT 0,  -- 新增不可用
  error_models INTEGER DEFAULT 0,       -- 错误的模型数
  created_at TEXT DEFAULT (datetime('now')),
  updated_at TEXT DEFAULT (datetime('now'))
);
```

### 4. model_checker_run_models (巡检详情)
```sql
CREATE TABLE model_checker_run_models (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  run_id INTEGER NOT NULL,              -- 关联 model_checker_runs.id
  model_id TEXT NOT NULL,               -- 模型 ID
  provider TEXT,                        -- 提供商
  status TEXT NOT NULL,                 -- 本次状态（available/unavailable/error）
  available_keys TEXT,                  -- 可用的 Key 列表（JSON 数组）
  error_message TEXT,                   -- 错误信息
  change_type TEXT,                     -- 变更类型（no_change/newly_available/newly_unavailable/keys_changed）
  checked_at TEXT,                      -- 检查时间
  created_at TEXT DEFAULT (datetime('now')),
  FOREIGN KEY (run_id) REFERENCES model_checker_runs(id) ON DELETE CASCADE
);

CREATE INDEX idx_model_checker_run_models_run_id ON model_checker_run_models(run_id);
CREATE INDEX idx_model_checker_run_models_model_id ON model_checker_run_models(model_id);
```

